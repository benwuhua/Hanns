HANNS_REMOTE_HOST=127.0.0.1
HANNS_REMOTE_USER=root
HANNS_REMOTE_PORT=22
HANNS_REMOTE_WORK_ROOT=/data/work
HANNS_REMOTE_REPO_DIR=/data/work/hanns-src
HANNS_REMOTE_TARGET_DIR=/data/work/hanns-target
HANNS_REMOTE_LOG_DIR=/data/work/hanns-logs
HANNS_REMOTE_NATIVE_REPO_URL=https://github.com/zilliztech/knowhere.git
HANNS_REMOTE_NATIVE_REPO_DIR=/data/work/knowhere-native-src
HANNS_REMOTE_NATIVE_BUILD_DIR=/data/work/knowhere-native-build-benchmark
HANNS_REMOTE_NATIVE_LOG_DIR=/data/work/knowhere-native-logs
HANNS_SSH_IDENTITY_FILE=~/.ssh/id_rsa
HANNS_DEFAULT_BRANCH=main
HANNS_DEFAULT_BUILD_TYPE=Release
HANNS_REMOTE_CARGO_ENV_FILE=$HOME/.cargo/env
HANNS_REMOTE_RUSTUP_TOOLCHAIN=
