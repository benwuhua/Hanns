KNOWHERE_RS_REMOTE_HOST=127.0.0.1
KNOWHERE_RS_REMOTE_USER=root
KNOWHERE_RS_REMOTE_PORT=22
KNOWHERE_RS_REMOTE_WORK_ROOT=/data/work
KNOWHERE_RS_REMOTE_REPO_DIR=/data/work/knowhere-rs-src
KNOWHERE_RS_REMOTE_TARGET_DIR=/data/work/knowhere-rs-target
KNOWHERE_RS_REMOTE_LOG_DIR=/data/work/knowhere-rs-logs
KNOWHERE_RS_REMOTE_NATIVE_REPO_URL=https://github.com/zilliztech/knowhere.git
KNOWHERE_RS_REMOTE_NATIVE_REPO_DIR=/data/work/knowhere-native-src
KNOWHERE_RS_REMOTE_NATIVE_BUILD_DIR=/data/work/knowhere-native-build-benchmark
KNOWHERE_RS_REMOTE_NATIVE_LOG_DIR=/data/work/knowhere-native-logs
KNOWHERE_RS_SSH_IDENTITY_FILE=~/.ssh/id_rsa
KNOWHERE_RS_DEFAULT_BRANCH=main
KNOWHERE_RS_DEFAULT_BUILD_TYPE=Release
KNOWHERE_RS_REMOTE_CARGO_ENV_FILE=$HOME/.cargo/env
